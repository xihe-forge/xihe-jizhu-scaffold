{
  "mode": "interactive",
  "granularity": "standard",
  "responsive_breakpoints": [],
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true
  },
  "gates": {
    "confirm_project": true,
    "confirm_phases": true,
    "confirm_roadmap": true,
    "confirm_breakdown": true,
    "confirm_plan": true,
    "issues_review": true,
    "confirm_transition": true
  },
  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true
  },
  "discipline": {
    "tdd_default": true,
    "code_review_required": true,
    "verification_required": true
  },
  "review_gates": {
    "mrd_prd_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-mrd-prd.md",
      "tools": [],
      "triggers": ["docs/mrd/", "docs/prd/", ".planning/REQUIREMENTS.md"]
    },
    "tech_design_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-tech-design.md",
      "tools": ["impeccable", "vercel-web-design"],
      "triggers": ["docs/tech/", "docs/design/"]
    },
    "code_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-code.md",
      "tools": ["impeccable", "vercel-web-design"],
      "triggers": ["apps/", "packages/"]
    },
    "test_coverage_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-test-coverage.md",
      "tools": [],
      "triggers": ["test/", "*.test.*", "*.spec.*"],
      "require_full_prd_coverage": true
    },
    "marketing_review": {
      "enabled": true,
      "blocking": false,
      "recipe": ".ai/recipes/review-marketing.md",
      "tools": [],
      "triggers": ["docs/marketing/", "docs/mrd/"]
    },
    "seo_aeo_review": {
      "enabled": true,
      "blocking": false,
      "recipe": ".ai/recipes/review-seo-aeo.md",
      "tools": ["xihe-search-forge"],
      "triggers": ["apps/web/", "apps/*/src/app/", "public/", "src/app/"]
    }
  },
  "optional_modules": {
    "payment": {
      "enabled": false,
      "provider": "creem",
      "recipe": ".ai/recipes/payment-integration-guide.md",
      "payout_method": "wise"
    }
  },
  "user_profile": "standard",
  "review_strategy": {
    "mode": "auto",
    "custom_rounds": null,
    "zero_bug_threshold": 3
  },
  "final_review": {
    "enabled": true,
    "max_rounds": "auto",
    "parallel_reviewers": {
      "docs": ["opus", "codex"],
      "code": ["sonnet", "codex"]
    },
    "recipe": ".ai/recipes/review-final-iteration.md",
    "convergence": "zero_new_issues"
  },
  "review_tools": {
    "impeccable": {
      "path": ".ai/skills/impeccable",
      "description": "Frontend design anti-patterns, 17 audit commands"
    },
    "vercel-web-design": {
      "path": ".ai/skills/vercel-web-design",
      "description": "Vercel-style web design patterns and best practices"
    },
    "xihe-search-forge": {
      "path": ".ai/skills/xihe-search-forge",
      "description": "SEO + AEO audit — crawl, Schema validation, llms.txt, FAQ extraction, Lighthouse comparison",
      "skills": ["seo-audit", "aeo-audit", "seo-report", "aeo-monitor"],
      "scripts": {
        "crawl": "node scripts/crawl-page.mjs",
        "llms-txt": "node scripts/generate-llms-txt.mjs",
        "ai-citation": "node scripts/check-ai-citation.mjs"
      }
    }
  }
}
