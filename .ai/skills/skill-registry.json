{
  "version": "1.0.0",
  "description": "External skill modules registry. Autopilot uses this to determine which skills to invoke at each phase.",

  "execution_order": {
    "implement_frontend": ["impeccable/frontend-design"],
    "review_frontend": [
      "impeccable/critique",
      "vercel-web-design/web-design-guidelines",
      "impeccable/audit",
      "impeccable/normalize",
      "impeccable/polish"
    ],
    "review_seo": [
      "xihe-rinian-seo/seo-audit",
      "xihe-rinian-seo/aeo-audit",
      "xihe-rinian-seo/aeo-monitor",
      "xihe-rinian-seo/seo-report"
    ],
    "final_review": [
      "impeccable/audit",
      "vercel-web-design/web-design-guidelines",
      "xihe-rinian-seo/seo-audit",
      "xihe-rinian-seo/aeo-audit",
      "xihe-rinian-seo/aeo-monitor",
      "xihe-rinian-seo/seo-report"
    ]
  },

  "skills": {
    "impeccable": {
      "version": "1.0.0",
      "description": "Frontend design generation and iterative refinement. Anti-AI-slop aesthetics.",
      "source": "https://github.com/pbakaus/impeccable",
      "license": "Apache 2.0",
      "path": ".ai/skills/impeccable",
      "trigger": {
        "phase": ["implement", "review"],
        "task_tags": ["frontend", "ui", "design", "component", "page", "layout"],
        "file_patterns": ["*.tsx", "*.jsx", "*.vue", "*.svelte", "*.css", "*.scss"]
      },
      "skills": {
        "frontend-design": {
          "file": "source/skills/frontend-design/SKILL.md",
          "role": "design_generator",
          "when": "Creating new UI components, pages, or layouts",
          "requires_context": true,
          "context_file": ".impeccable.md"
        },
        "teach-impeccable": {
          "file": "source/skills/teach-impeccable/SKILL.md",
          "role": "setup",
          "when": "First-time setup or when .impeccable.md is missing"
        },
        "polish": {
          "file": "source/skills/polish/SKILL.md",
          "role": "design_refinement",
          "when": "Final quality pass before shipping frontend",
          "depends_on": "impeccable/audit"
        },
        "audit": {
          "file": "source/skills/audit/SKILL.md",
          "role": "design_audit",
          "when": "Comprehensive UI quality audit (accessibility, performance, theming, responsive)"
        },
        "critique": {
          "file": "source/skills/critique/SKILL.md",
          "role": "design_review",
          "when": "Evaluating design effectiveness and UX quality"
        },
        "harden": {
          "file": "source/skills/harden/SKILL.md",
          "role": "design_hardening",
          "when": "Improving error handling, i18n, edge cases in UI"
        },
        "normalize": {
          "file": "source/skills/normalize/SKILL.md",
          "role": "design_consistency",
          "when": "Aligning implementation with design system",
          "depends_on": "impeccable/critique"
        },
        "optimize": {
          "file": "source/skills/optimize/SKILL.md",
          "role": "performance",
          "when": "Improving frontend performance (loading, rendering, bundle size)"
        },
        "distill": {
          "file": "source/skills/distill/SKILL.md",
          "role": "design_simplification",
          "when": "Removing unnecessary UI complexity"
        },
        "extract": {
          "file": "source/skills/extract/SKILL.md",
          "role": "component_extraction",
          "when": "Extracting reusable components and design tokens"
        }
      },
      "reference": {
        "path": "source/skills/frontend-design/reference/",
        "files": [
          "typography.md",
          "color-and-contrast.md",
          "spatial-design.md",
          "motion-design.md",
          "interaction-design.md",
          "responsive-design.md",
          "ux-writing.md"
        ]
      }
    },

    "vercel-web-design": {
      "version": "1.0.0",
      "description": "Web Interface Guidelines compliance review. Engineering-grade UX quality gate (accessibility, performance, standards).",
      "source": "https://github.com/vercel-labs/agent-skills",
      "license": "MIT",
      "path": ".ai/skills/vercel-web-design",
      "trigger": {
        "phase": ["review", "final_review"],
        "task_tags": ["frontend", "ui", "design", "accessibility", "ux"],
        "file_patterns": ["*.tsx", "*.jsx", "*.vue", "*.svelte", "*.html"]
      },
      "skills": {
        "web-design-guidelines": {
          "file": "skills/web-design-guidelines/SKILL.md",
          "role": "engineering_review",
          "when": "Reviewing frontend code for Web Interface Guidelines compliance"
        }
      }
    },

    "xihe-rinian-seo": {
      "version": "0.2.0",
      "description": "SEO & AEO audit, monitoring, and reporting. AI search optimization and traditional SEO quality gates.",
      "source": "https://github.com/xihe-forge/xihe-rinian-seo",
      "license": "MIT",
      "path": ".ai/skills/xihe-rinian-seo",
      "trigger": {
        "phase": ["review", "final_review", "deploy"],
        "task_tags": ["seo", "aeo", "geo", "search", "marketing", "landing-page", "public-page"],
        "file_patterns": ["*.html", "*.tsx", "*.jsx"]
      },
      "skills": {
        "seo-audit": {
          "file": "skills/xihe-rinian-seo/SKILL.md",
          "role": "seo_audit",
          "when": "Full SEO audit with Lighthouse integration for public-facing pages"
        },
        "aeo-audit": {
          "file": "skills/xihe-rinian-seo-aeo/SKILL.md",
          "role": "aeo_audit",
          "when": "AI Answer Engine Optimization audit (9-dimension scoring) for AI search visibility"
        },
        "aeo-monitor": {
          "file": "skills/xihe-rinian-seo-citation/SKILL.md",
          "role": "aeo_monitoring",
          "when": "AI search citation tracking, sentiment analysis, and competitor comparison"
        },
        "seo-report": {
          "file": "skills/xihe-rinian-seo-report/SKILL.md",
          "role": "seo_reporting",
          "when": "Before/after comparison and impact analysis of SEO/AEO changes",
          "depends_on": "xihe-rinian-seo/seo-audit"
        }
      }
    }
  },

  "phase_mapping": {
    "implement_frontend": {
      "design": ["impeccable/frontend-design"]
    },
    "review_frontend": {
      "aesthetic_review": ["impeccable/critique", "impeccable/audit"],
      "engineering_review": ["vercel-web-design/web-design-guidelines"],
      "refinement": ["impeccable/polish", "impeccable/normalize"]
    },
    "review_seo": {
      "seo_gate": ["xihe-rinian-seo/seo-audit", "xihe-rinian-seo/aeo-audit"],
      "monitoring": ["xihe-rinian-seo/aeo-monitor"],
      "reporting": ["xihe-rinian-seo/seo-report"]
    },
    "final_review": {
      "qa_gate": ["impeccable/audit", "vercel-web-design/web-design-guidelines"],
      "search_gate": ["xihe-rinian-seo/seo-audit", "xihe-rinian-seo/aeo-audit", "xihe-rinian-seo/aeo-monitor", "xihe-rinian-seo/seo-report"]
    }
  }
}
